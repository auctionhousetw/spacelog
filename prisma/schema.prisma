generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
  url      = env("DATABASE_URL")
}

model lvr_land {
  id             String  @id
  city           String?
  district       String?
  address        String?
  tx_type        String?
  tx_date        String?
  tx_date_iso    String?
  total_price    Float?
  unit_price_sqm Float?
  building_type  String?
  main_use       String?
  area_sqm       Float?
  bedrooms       Int?
  halls          Int?
  bathrooms      Int?
  elevator       String?
  total_floors   String?
  floor          String?
  land_area_sqm  Float?
  main_area      Float?
  aux_area       Float?
  balcony_area   Float?
  build_complete String?
  season         String?
  notes          String?

  @@index([city],        map: "idx_lvr_city")
  @@index([district],    map: "idx_lvr_district")
  @@index([tx_date_iso], map: "idx_lvr_date")
  @@index([total_price], map: "idx_lvr_price")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model houses {
  id             String @id
  title          String?
  url            String?
  city           String?
  district       String?
  address        String?
  type           String?
  status         String?
  case_number    String?
  price          Float?
  unit_price     Float?
  unit_price_str String?
  next_price     Float?
  deposit        String?
  area           Float?
  total_ping     String?
  main_ping      String?
  sub_ping       String?
  extra_ping     String?
  land_ping      String?
  layout         String?
  floor          String?
  age            String?
  elevator       String?
  parking        String?
  corner         String?
  orientation    String?
  community      String?
  courtyard      String?
  hoa            String?
  haunted        String?
  auction_date   String?
  auction_time   String?
  auction_round  String?
  delivery       String?
  land_use       String?
  near_school    String?
  near_traffic   String?
  living         String?
  agent          String?
  company        String?
  description    String?
  bcr            String?
  far            String?
  land_category  String?
  source             String?
  source_id          String?
  category           String?
  is_agent_featured  Int?

  @@index([city], map: "idx_city")
  @@index([district], map: "idx_district")
  @@index([price], map: "idx_price")
}

model lvr_presale {
  id             String  @id
  city           String?
  district       String?
  project_name   String?
  building_unit  String?
  address        String?
  floor          String?
  total_floors   String?
  building_type  String?
  main_use       String?
  build_complete String?
  area_sqm       Float?
  main_area      Float?
  aux_area       Float?
  balcony_area   Float?
  bedrooms       Int?
  halls          Int?
  bathrooms      Int?
  elevator       String?
  total_price    Float?
  unit_price_sqm Float?
  parking_price  Float?
  tx_date        String?
  tx_date_iso    String?
  season         String?
  notes          String?

  @@index([city],             map: "idx_presale_city")
  @@index([district],         map: "idx_presale_district")
  @@index([tx_date_iso],      map: "idx_presale_date")
  @@index([project_name],     map: "idx_presale_project")
  @@index([city, district],   map: "idx_presale_city_dist")
}

model inherited_land {
  id                 String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  city               String?
  district           String?
  land_office        String?
  announcement_start String?
  announcement_end   String?
  application_end    String?
  source_url         String?
  scraped_date       String?

  @@index([city],     map: "idx_inherit_city")
  @@index([district], map: "idx_inherit_dist")
}

model rezoning_case {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  city            String?
  case_name       String?
  status          String?
  content_summary String?
  source_url      String?
  scraped_date    String?

  @@index([city], map: "idx_rezoning_city")
  @@unique([city, case_name], map: "uq_rezoning_case")
}

model lvr_land_section {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tx_id        String
  segment_name String?
  lot_number   String?
  area_sqm     Float?

  @@index([tx_id],        map: "idx_section_tx")
  @@index([segment_name], map: "idx_section_seg")
}
